prefix=${pcfiledir}/../..
exec_prefix=${prefix}
symbol_prefix=
libdir=${exec_prefix}/lib
sharedlibdir=${libdir}
includedir=${prefix}/include

Name: zlib-ng
Description: zlib-ng compression library
Version: 2.2.4


Libs: "-L${libdir}" "-L${sharedlibdir}" -lz-ng
Requires: 
Cflags: "-I${includedir}" -DWITH_GZFILEOP
